<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/btnBrainBreak"
        android:layout_width="233dp"
        android:layout_height="81dp"
        android:layout_marginStart="88dp"
        android:layout_marginTop="90dp"
        android:backgroundTint="@color/grey"
        android:text="Brain Break"
        android:textColor="#000000"
        android:textSize="24sp"
        app:icon="@drawable/controller"
        app:iconPadding="0dp"
        app:iconSize="50dp"
        app:iconTint="@color/black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/TitleText" />

    <Button
        android:id="@+id/btnSettings"
        android:layout_width="233dp"
        android:layout_height="81dp"
        android:layout_marginStart="88dp"
        android:layout_marginTop="35dp"
        android:backgroundTint="@color/lightgrey"
        android:text="Settings"
        android:textColor="#000000"
        android:textSize="24sp"
        app:icon="@drawable/settings"
        app:iconPadding="0dp"
        app:iconSize="50dp"
        app:iconTint="@color/black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnBrainBreak" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="176dp"
        android:text="Button"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="226dp" />
        android:layout_marginTop="-83dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/venomblob" />

    <TextView
        android:id="@+id/TitleText"
        android:layout_width="187dp"
        android:layout_height="57dp"
        android:layout_marginStart="-280dp"
        android:layout_marginTop="-75dp"
        android:fontFamily="@font/black_han_sans"
        android:text="Inkur"
        android:textSize="60sp"
        app:layout_constraintStart_toEndOf="@+id/imageView"
        app:layout_constraintTop_toBottomOf="@+id/imageView" />

    <Switch
        android:id="@+id/btnSwitch"
        android:layout_width="74dp"
        android:layout_height="57dp"
        android:layout_centerInParent="true"
        android:layout_marginEnd="161dp"
        android:layout_marginBottom="20dp"
        android:checked="true"
        android:scaleX="1.5"
        android:scaleY="1.5"
        android:thumb="@drawable/button"
        android:track="@drawable/switchbutton"
        app:layout_constraintBottom_toTopOf="@+id/btnBrainBreak"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>