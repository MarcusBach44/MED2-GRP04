<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">


    <Button
        android:id="@+id/btnBrainBreak"
        android:layout_width="233dp"
        android:layout_height="80dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginStart="89dp"
        android:layout_marginEnd="89dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#000"
        android:text="Brain Break"
        android:textColor="@color/white"
        android:textSize="24sp"
        app:icon="@drawable/controller"
        app:layout_constraintBottom_toTopOf="@+id/btnSettings"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        />

    <Button
        android:id="@+id/btnSettings"
        android:layout_width="233dp"
        android:layout_height="80dp"
        android:layout_marginStart="89dp"
        android:layout_marginEnd="89dp"
        android:layout_marginBottom="37dp"
        android:backgroundTint="@color/lightgrey"
        android:text="Settings"
        android:textColor="#000000"
        android:textSize="24sp"
        app:icon="@drawable/settings"
        app:iconPadding="0dp"
        app:iconSize="50dp"
        app:iconTint="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/venomblob"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="-92dp" />

    <TextView
        android:id="@+id/TitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"

        android:layout_marginEnd="2dp"
        android:layout_marginBottom="28dp"
        android:fontFamily="sans-serif-medium"
        android:text="Inkur"
        android:textAlignment="center"
        android:textColor="#000"
        android:textSize="48sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/btnSwitch"
        app:layout_constraintEnd_toStartOf="@+id/imageView"
        app:layout_constraintStart_toEndOf="@+id/imageView" />

    <Switch
        android:id="@+id/btnSwitch"
        android:layout_width="74dp"
        android:layout_height="57dp"
        android:layout_centerInParent="true"
        android:layout_marginEnd="161dp"
        android:layout_marginBottom="25dp"
        android:checked="false"
        android:scaleX="1.5"
        android:scaleY="1.5"
        android:thumb="@drawable/button"
        android:track="@drawable/switchbutton"
        app:layout_constraintBottom_toTopOf="@+id/btnBrainBreak"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>