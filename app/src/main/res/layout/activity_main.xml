<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MainActivity">


    <Button
        android:id="@+id/btnBrainBreak"
        android:layout_width="233dp"
        android:layout_height="80dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginStart="89dp"
        android:layout_marginEnd="89dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#000"
        android:fontFamily="@font/poppins_semibold"
        android:text="Brain Break"
        android:textColor="@color/white"
        android:textSize="24sp"
        app:icon="@drawable/controller"
        app:layout_constraintBottom_toTopOf="@+id/btnSettings"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnSettings"
        android:layout_width="233dp"
        android:layout_height="80dp"
        android:layout_marginStart="89dp"
        android:layout_marginEnd="89dp"
        android:layout_marginBottom="37dp"
        android:backgroundTint="@color/lightgrey"
        android:fontFamily="@font/poppins_semibold"
        android:text="Settings"
        android:textColor="#000000"
        android:textSize="26sp"
        app:icon="@drawable/settings"
        app:iconPadding="0dp"
        app:iconSize="24dp"
        app:iconTint="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


<!--    <ImageView-->
<!--        android:id="@+id/clickableInkyGif"-->
<!--        android:layout_width="200dp"-->
<!--        android:layout_height="200dp"-->
<!--        android:src="@drawable/clickableInky"-->
<!--        android:clickable="true"-->
<!--        android:focusable="true"-->
<!--        tools:layout_editor_absoluteX="105dp"-->
<!--        tools:layout_editor_absoluteY="149dp" />-->

    <TextView
        android:id="@+id/TitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_marginEnd="-257dp"
        android:layout_marginBottom="280dp"
        android:fontFamily="@font/poppins_semibold"
        android:text="Inkur"
        android:textAlignment="center"
        android:textColor="#000"
        android:textSize="70sp"
        android:textStyle="bold|italic"
        app:layout_constraintBottom_toTopOf="@+id/btnSwitch"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.23"
        app:layout_constraintStart_toStartOf="parent" />

    <Switch
        android:id="@+id/btnSwitch"
        android:layout_width="74dp"
        android:layout_height="57dp"
        android:layout_centerInParent="true"
        android:layout_marginEnd="176dp"
        android:layout_marginBottom="40dp"
        android:checked="false"
        android:scaleX="1.5"
        android:scaleY="1.5"
        android:thumb="@drawable/button"
        android:track="@drawable/switchbutton"
        app:layout_constraintBottom_toTopOf="@+id/btnBrainBreak"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/inkyhomepage"
        android:layout_width="294dp"
        android:layout_height="328dp"
        android:layout_marginStart="58dp"
        android:layout_marginTop="-30dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/TitleText"
        app:srcCompat="@drawable/inkyhomepage" />

    <ImageView
        android:id="@+id/shadow"
        android:layout_width="215dp"
        android:layout_height="167dp"
        android:layout_marginStart="95dp"
        android:layout_marginTop="-170dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/inkyhomepage"
        app:srcCompat="@drawable/circleshadow" />


</androidx.constraintlayout.widget.ConstraintLayout>