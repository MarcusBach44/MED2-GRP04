<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Settings_Options">


    <TextView
        android:id="@+id/txtSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:fontFamily="@font/poppins_semibold"
        android:gravity="center"
        android:text="Settings"
        android:textColor="@color/black"
        android:textSize="30sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/BackButton"
        android:layout_width="55dp"
        android:layout_height="50dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="25dp"
        android:backgroundTint="#FBF8F8"
        android:contentDescription="BackButton"
        android:scaleX="2"
        android:scaleY="2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="?attr/actionModeCloseDrawable" />

    <ImageView
        android:id="@+id/inky"
        android:layout_width="139dp"
        android:layout_height="159dp"
        android:layout_marginStart="136dp"
        android:layout_marginTop="532dp"
        android:scaleX="2.5"
        android:scaleY="2.5"
        android:visibility="visible"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/smallinky" />

    <Button
        android:id="@+id/button"
        android:layout_width="233dp"
        android:layout_height="81dp"
        android:layout_marginStart="88dp"
        android:layout_marginTop="200dp"
        android:backgroundTint="#BFBBBB"
        android:fontFamily="@font/poppins_semibold"
        android:text="Restricted apps"
        android:textColor="@color/black"
        android:textSize="22sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnSleepTime"
        android:layout_width="233dp"
        android:layout_height="81dp"
        android:layout_marginStart="88dp"
        android:layout_marginTop="320dp"
        android:backgroundTint="#BFBBBB"
        android:fontFamily="@font/poppins_semibold"
        android:text="Sleep Time"
        android:textColor="@color/black"
        android:textSize="22sp"
        app:icon="@drawable/sleepmode"
        app:iconPadding="0dp"
        app:iconSize="50dp"
        app:iconTint="@color/black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>